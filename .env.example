# Port exposed on the host machine.
HOLIDAYCHECK_PORT=3000

# Session lifetime in seconds.
SESSION_TTL_SECONDS=86400

# App language: de or en.
HOLIDAYCHECK_LANGUAGE=de

# Watchtower automatic update check.
TZ=Europe/Zurich
WATCHTOWER_SCHEDULE=0 0 4 * * *

# User management.
# Add users as a clean numbered list. User 1 is required.
HOLIDAYCHECK_USER_1_NAME=admin
HOLIDAYCHECK_USER_1_PASSWORD=change-this-password

HOLIDAYCHECK_USER_2_NAME=
HOLIDAYCHECK_USER_2_PASSWORD=

# Optional extra users. Leave empty or fill both name and password.
HOLIDAYCHECK_USER_3_NAME=
HOLIDAYCHECK_USER_3_PASSWORD=
HOLIDAYCHECK_USER_4_NAME=
HOLIDAYCHECK_USER_4_PASSWORD=
HOLIDAYCHECK_USER_5_NAME=
HOLIDAYCHECK_USER_5_PASSWORD=
